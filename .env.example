# ---------------------------------------------------------------------------
# trelix — environment configuration
# Copy to .env and fill in the values you need.
# Never commit .env.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Embeddings provider (TRELIX_EMBEDDER_PROVIDER)
# Default: local (no API key needed)
# Options: local | openai | azure | voyage | local-code | bedrock-titan | bedrock-cohere
# ---------------------------------------------------------------------------
TRELIX_EMBEDDER_PROVIDER=local

# ── OpenAI embeddings ────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# TRELIX_EMBEDDER_OPENAI_MODEL=text-embedding-3-large

# ── Azure OpenAI embeddings + chat ──────────────────────────────────────────
# AZURE_API_KEY=...
# AZURE_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_API_VERSION=2025-04-01-preview
# AZURE_EMBEDDINGS_MODEL=text-embedding-3-large
# AZURE_CHAT_MODEL=gpt-4o

# ── Voyage AI embeddings (best API-based code retrieval — pip install trelix[voyage])
# CoIR benchmark: 56.26 avg — best API option for code retrieval
# VOYAGE_API_KEY=...
# TRELIX_EMBEDDER_VOYAGE_MODEL=voyage-code-3    # 1024-dim, 16k context

# ── Local sentence-transformers embeddings (no API key, CPU) ─────────────────
# Enabled by default when TRELIX_EMBEDDER_PROVIDER=local
# No additional variables required.

# ── Local code-specialized embeddings (SFR-Embedding-Code-2B_R, ~8GB RAM/GPU)
# pip install trelix[local-code]
# TRELIX_EMBEDDER_PROVIDER=local-code

# ---------------------------------------------------------------------------
# LLM provider for chat/synthesis (TRELIX_LLM_PROVIDER)
# Default: reads OPENAI_API_KEY / AZURE_API_KEY from above
# Options: openai | azure | anthropic | bedrock | vertex | litellm
# ---------------------------------------------------------------------------
# TRELIX_LLM_PROVIDER=openai
# TRELIX_LLM_MODEL=gpt-4o
# OPENAI_MODEL=gpt-4o                           # chat model for planner + synthesizer

# ── Anthropic direct (pip install trelix[anthropic]) ─────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── AWS Bedrock — chat + embeddings (pip install trelix[bedrock]) ─────────────
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# AWS_PROFILE=my-profile                        # alternative to key/secret
#
# Bedrock chat model selection (inference profile IDs — us.* prefix required):
# TRELIX_LLM_BEDROCK_PRIMARY_MODEL=us.anthropic.claude-sonnet-4-6
# TRELIX_LLM_BEDROCK_FALLBACK_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
#
# Bedrock embeddings:
# TRELIX_EMBEDDER_PROVIDER=bedrock-titan        # 256 | 512 | 1024 dims
# TRELIX_EMBEDDER_PROVIDER=bedrock-cohere       # 1024 dims, asymmetric retrieval

# ── Google Vertex AI / Gemini (pip install trelix[vertex]) ────────────────────
# GOOGLE_CLOUD_PROJECT=my-project
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_API_KEY=...                            # for AI Studio (alternative to project)

# ── LiteLLM passthrough — 100+ providers (pip install trelix[litellm]) ────────
# TRELIX_LLM_PROVIDER=litellm
# TRELIX_LLM_LITELLM_MODEL=bedrock/claude-3-5-sonnet  # any LiteLLM model string

# ---------------------------------------------------------------------------
# Cohere reranker (optional, best precision — pip install trelix[rerank])
# ---------------------------------------------------------------------------
# COHERE_API_KEY=...
# COHERE_ENDPOINT=https://...                   # Azure-deployed Cohere endpoint
# COHERE_MODEL_RERANK=Cohere-rerank-v4.0-pro

# ---------------------------------------------------------------------------
# Contextual chunking (LLM summaries per chunk, 67% better recall)
# Costs LLM tokens at index time; off by default
# ---------------------------------------------------------------------------
# TRELIX_CHUNKER_CONTEXTUAL=false
# TRELIX_CHUNKER_CONTEXTUAL_MODEL=gpt-4o-mini
# TRELIX_CHUNKER_CONTEXTUAL_MAX_TOKENS=100

# ---------------------------------------------------------------------------
# Store / vector DB
# Default: sqlite (zero-infra). Use qdrant for >500k chunk scale.
# ---------------------------------------------------------------------------
# TRELIX_STORE_BACKEND=sqlite                   # sqlite | qdrant
# TRELIX_STORE_HNSW=true                        # enable HNSW O(log n) index
# TRELIX_STORE_HNSW_M=16
# TRELIX_STORE_HNSW_EF_SEARCH=50

# Qdrant (pip install trelix[qdrant])
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=...
# QDRANT_COLLECTION=trelix

# ---------------------------------------------------------------------------
# Retrieval tuning
# ---------------------------------------------------------------------------
# TRELIX_RETRIEVAL_RERANK_PROVIDER=none         # none | cohere | cross_encoder
# TRELIX_RETRIEVAL_RERANK_TOP_N=15
# TRELIX_RETRIEVAL_CONTEXT_TOKEN_BUDGET=12000
# TRELIX_RETRIEVAL_SYNTHESIS_MAX_TOKENS=12000
# TRELIX_RETRIEVAL_GRAPH_IMPORT_MAX_EXTRA=3

# GraphRAG map-reduce synthesis
# Activates when results exceed either threshold
# TRELIX_RETRIEVAL_GRAPH_RAG=true
# TRELIX_RETRIEVAL_GRAPH_RAG_THRESHOLD_TOKENS=8000
# TRELIX_RETRIEVAL_GRAPH_RAG_THRESHOLD_RESULTS=20

# ---------------------------------------------------------------------------
# Indexing tuning
# ---------------------------------------------------------------------------
# TRELIX_PARSE_WORKERS=4                        # parallel parse threads
# TRELIX_EMBEDDER_EMBED_MAX_TOKENS_PER_BATCH=100000
# TRELIX_EMBEDDER_TPM_LIMIT=0                   # 0 = unlimited
