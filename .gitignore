# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
*.egg
build/
.eggs/
pip-wheel-metadata/

# dist/ — ignore generated packaging artefacts but ship the codeindex binary.
# Using dist/* (not dist/) so that negation rules for tracked files work.
dist/*
!dist/.gitkeep
!dist/codeindex

# Virtual environments
.venv/
venv/
env/
ENV/

# Trelix index data — never commit these
.trelix/

# Test / coverage artefacts
.pytest_cache/
.coverage
htmlcov/
.tox/

# Ruff / Mypy caches
.ruff_cache/
.mypy_cache/

# Environment files — secrets must not be committed
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db

# Distribution / packaging
*.tar.gz
*.whl
MANIFEST
